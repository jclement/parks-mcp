# Copy to .env and fill in. The token id (before the ':') is the tunnel name.
GATECRASH_SERVER=your-gatecrash-server:55808
GATECRASH_HOST_KEY=SHA256:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GATECRASH_TOKEN=parks:your-tunnel-secret
GATECRASH_TARGET=127.0.0.1:8000

MCP_PATH=/burrow/9f3a7c2e1d/mcp

# Cache TTLs (seconds). Metadata (campground list/descriptions) rarely changes;
# availability changes often. Set a TTL to 0 to disable caching for that class.
CAMPGROUND_CACHE_TTL=604800   # 7 days
AVAILABILITY_CACHE_TTL=300    # 5 minutes
